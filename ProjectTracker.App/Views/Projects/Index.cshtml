@model List<ProjectTracker.Web.ViewModels.Projects.ProjectListViewModel>

@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-project-diagram"></i> Projects</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Project
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> No projects found.
        @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
        {
            <a asp-action="Create">Create your first project</a>
        }
    </div>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@project.Id" class="text-decoration-none">
                                    @project.Name
                                </a>
                            </h5>
                            <span class="badge bg-@(project.Status == "Active" ? "success" :
                                                                                  project.Status == "OnHold" ? "warning" :
                                                                                  project.Status == "Completed" ? "info" : "secondary")">
                                @project.Status
                            </span>
                        </div>
                        <p class="card-text text-muted small">@(project.Description?.Length > 100 ? project.Description.Substring(0, 100) + "..." : project.Description)</p>

                        <div class="progress mb-2" style="height: 5px;">
                            <div class="progress-bar" style="width: @project.CompletionPercentage%"></div>
                        </div>
                        <div class="d-flex justify-content-between small text-muted mb-3">
                            <span><i class="fas fa-tasks"></i> @project.CompletedWorkItemsCount/@project.WorkItemsCount tasks</span>
                            <span>@project.CompletionPercentage% complete</span>
                        </div>

                        <div class="d-flex justify-content-between text-muted small">
                            <span><i class="fas fa-user"></i> @project.OwnerName</span>
                            <span><i class="fas fa-users"></i> @project.TeamMembersCount members</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-eye"></i> View
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
                        {
                            <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}