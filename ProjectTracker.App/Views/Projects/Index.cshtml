@model ProjectTracker.Web.ViewModels.Projects.ProjectIndexViewModel

@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-project-diagram"></i> Projects</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Project
        </a>
    }
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filter Projects</h5>
    </div>
    <div class="card-body">
        <form method="get" id="filterForm" class="row g-3">
            <!-- Search -->
            <div class="col-md-4">
                <label class="form-label fw-bold">Search</label>
                <input type="text" name="SearchTerm" class="form-control"
                       placeholder="Search by name..." value="@Model.Filter.SearchTerm" />
            </div>

            <!-- Status Filter -->
            <div class="col-md-3">
                <label class="form-label fw-bold">Status</label>
                <select name="Status" class="form-select">
                    @foreach (var status in Model.Filter.Statuses)
                    {
                        var selected = Model.Filter.Status == status;
                        <option value="@status" selected="@selected">@status</option>
                    }
                </select>
            </div>

            <!-- Sort By -->
            <div class="col-md-3">
                <label class="form-label fw-bold">Sort By</label>
                <select name="SortBy" class="form-select">
                    @foreach (var option in Model.Filter.SortOptions)
                    {
                        var selected = Model.Filter.SortBy == option.Value;
                        <option value="@option.Value" selected="@selected">@option.Text</option>
                    }
                </select>
            </div>

            <!-- Sort Direction -->
            <div class="col-md-2">
                <label class="form-label fw-bold">Order</label>
                <select name="SortDescending" class="form-select">
                    <option value="true" selected="@Model.Filter.SortDescending">Descending</option>
                    <option value="false" selected="!@Model.Filter.SortDescending">Ascending</option>
                </select>
            </div>

            <div class="text-center text-muted mt-3">
                <small>Showing @Model.Projects.Count of @Model.Pagination.TotalCount projects</small>
            </div>

            <div class="col-md-12">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Apply Filters
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-undo"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Projects.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="fas fa-info-circle fa-3x mb-3"></i>
        <h4>No projects found</h4>
        <p class="mb-0">Try changing your filter criteria or create a new project.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var project in Model.Projects)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">
                                <a asp-action="Details" asp-route-id="@project.Id" class="text-decoration-none">
                                    @project.Name
                                </a>
                            </h5>
                            <span class="badge @project.StatusBadgeClass">@project.Status</span>
                        </div>
                        <p class="card-text text-muted small">@(project.Description?.Length > 100 ? project.Description.Substring(0, 100) + "..." : project.Description ?? "No description")</p>

                        <div class="progress mb-2" style="height: 6px;">
                            <div class="progress-bar bg-success" style="width: @project.CompletionPercentage%"></div>
                        </div>
                        <div class="d-flex justify-content-between small text-muted mb-3">
                            <span><i class="fas fa-tasks"></i> @project.CompletedWorkItemsCount/@project.WorkItemsCount tasks</span>
                            <span>@project.CompletionPercentage% complete</span>
                        </div>

                        <div class="d-flex justify-content-between text-muted small">
                            <span><i class="fas fa-user"></i> @project.OwnerName</span>
                            <span><i class="fas fa-users"></i> @project.TeamMembersCount members</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-eye"></i> View
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
                        {
                            <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Pagination.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Pagination.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="#" data-page="@(Model.Filter.Page - 1)">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                </li>

                @for (int i = Model.Pagination.StartPage; i <= Model.Pagination.EndPage; i++)
                {
                    <li class="page-item @(Model.Filter.Page == i ? "active" : "")">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Pagination.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="#" data-page="@(Model.Filter.Page + 1)">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        // Pagination click handler
        document.querySelectorAll('.pagination .page-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.dataset.page;
                if (page) {
                    const form = document.getElementById('filterForm');
                    const pageInput = document.createElement('input');
                    pageInput.type = 'hidden';
                    pageInput.name = 'Page';
                    pageInput.value = page;
                    form.appendChild(pageInput);
                    form.submit();
                }
            });
        });
    </script>
}