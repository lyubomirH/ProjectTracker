@model ProjectTracker.Web.ViewModels.Projects.ProjectDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<!-- Page Header -->
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>@Model.Name</h2>
            <span class="badge @Model.StatusBadgeClass fs-6">@Model.Status</span>
        </div>
        <div>
            @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager") || Model.CurrentUserRole == "Owner")
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit"></i> Edit
                </a>
            }
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>
    <hr />
</div>

<div class="row">
    <!-- Main Content Column -->
    <div class="col-md-8">

        <!-- Description Card -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-align-left text-primary"></i> Description</h5>
            </div>
            <div class="card-body">
                @if (string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-0">No description provided.</p>
                }
                else
                {
                    <p class="mb-0">@Model.Description</p>
                }
            </div>
        </div>

        <!-- Work Items Card -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-tasks text-success"></i> Work Items (@Model.WorkItems.Count)</h5>
                <a asp-controller="WorkItems" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add Work Item
                </a>
            </div>
            <div class="card-body">
                @if (!Model.WorkItems.Any())
                {
                    <p class="text-muted text-center mb-0">No work items yet. Click "Add Work Item" to create one.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Assignee</th>
                                    <th>Due Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.WorkItems)
                                {
                                    <tr class="@(item.IsOverdue ? "table-danger" : "")">
                                        <td>
                                            <a asp-controller="WorkItems" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                                @item.Title
                                            </a>
                                        </td>
                                        <td><span class="badge @item.StatusBadgeClass">@item.Status</span></td>
                                        <td><span class="badge @item.PriorityBadgeClass">@item.Priority</span></td>
                                        <td>
                                            @if (item.AssigneeName == "Unassigned")
                                            {
                                                <span class="text-muted"><i class="fas fa-user-slash"></i> Unassigned</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-user"></i> 
                                                @item.AssigneeName
                                            }
                                        </td>
                                        <td class="@(item.IsOverdue ? "text-danger fw-bold" : "")">
                                            @if (item.IsOverdue)
                                            {
                                                <i class="fas fa-exclamation-triangle"></i>
                                            }
                                            @(item.DueDate?.ToString("yyyy-MM-dd") ?? "-")
                                        </td>
                                        <td>
                                            <a asp-controller="WorkItems" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar Column -->
    <div class="col-md-4">

        <!-- Project Info Card -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-info-circle text-info"></i> Project Info</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small">Owner</label>
                    <div><i class="fas fa-user"></i> @Model.OwnerName</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Start Date</label>
                    <div><i class="fas fa-calendar-alt"></i> @Model.StartDate.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">End Date</label>
                    <div><i class="fas fa-calendar-check"></i> @(Model.EndDate?.ToString("yyyy-MM-dd") ?? "Not set")</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Created At</label>
                    <div><i class="fas fa-clock"></i> @Model.CreatedAt.ToString("yyyy-MM-dd")</div>
                </div>
            </div>
        </div>

        <!-- Team Members Card -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-users text-primary"></i> Team Members (@Model.TeamMembers.Count)</h5>
                @if (Model.CurrentUserRole == "Owner" || Model.CurrentUserRole == "ProjectManager" || User.IsInRole("Admin"))
                {
                    <a asp-action="ManageTeam" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">
                        <i class="fas fa-cog"></i> Manage
                    </a>
                }
            </div>
            <div class="card-body">
                @if (!Model.TeamMembers.Any())
                {
                    <p class="text-muted text-center mb-0">No team members yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var member in Model.TeamMembers)
                        {
                            <li class="mb-2 pb-2 border-bottom">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fas fa-user-circle"></i> <strong>@member.UserName</strong>
                                        <br />
                                        <small class="text-muted ms-3">
                                            <span class="badge bg-secondary">@member.Role</span>
                                        </small>
                                    </div>
                                    @if (member.Role == "ProjectManager")
                                    {
                                        <span class="badge bg-info">Team Lead</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Quick Stats Card -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-chart-line text-warning"></i> Quick Stats</h5>
            </div>
            <div class="card-body text-center">
                @{
                    var totalTasks = Model.WorkItems.Count;
                    var completedTasks = Model.WorkItems.Count(w => w.Status == "Done");
                    var completionPercentage = totalTasks > 0 ? Math.Round((double)completedTasks / totalTasks * 100, 1) : 0;
                }

                <h2 class="mb-0">@completedTasks / @totalTasks</h2>
                <p class="text-muted">Tasks Completed</p>

                <div class="progress mb-3" style="height: 10px;">
                    <div class="progress-bar bg-success" style="width: @completionPercentage%"></div>
                </div>

                <div class="row mt-4">
                    <div class="col-6">
                        <small class="text-muted">To Do</small>
                        <h5 class="mb-0">@Model.WorkItems.Count(w => w.Status == "ToDo")</h5>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">In Progress</small>
                        <h5 class="mb-0">@Model.WorkItems.Count(w => w.Status == "InProgress")</h5>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <div class="col-6">
                        <small class="text-muted">Blocked</small>
                        <h5 class="mb-0 text-danger">@Model.WorkItems.Count(w => w.Status == "Blocked")</h5>
                    </div>
                    <div class="col-6">
                        <small class="text-muted">Code Review</small>
                        <h5 class="mb-0 text-info">@Model.WorkItems.Count(w => w.Status == "CodeReview")</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>