@model ProjectTracker.Web.ViewModels.Projects.ProjectDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>@Model.Name</h2>
            <span class="badge @Model.StatusBadgeClass fs-6">@Model.Status</span>
        </div>
        <div>
            @if (User.IsInRole("Admin") || User.IsInRole("ProjectManager"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit"></i> Edit
                </a>
            }
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>
    <hr />
</div>

<div class="row">
    <div class="col-md-8">
        <!-- Description Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-align-left"></i> Description</h5>
            </div>
            <div class="card-body">
                @if (string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-0">No description provided.</p>
                }
                else
                {
                    <p class="mb-0">@Model.Description</p>
                }
            </div>
        </div>
        
        <!-- Work Items Card -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-tasks"></i> Work Items (@Model.WorkItems.Count)</h5>
                <a asp-controller="WorkItems" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add Work Item
                </a>
            </div>
            <div class="card-body">
                @if (!Model.WorkItems.Any())
                {
                    <p class="text-muted text-center mb-0">No work items yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Assignee</th>
                                    <th>Due Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.WorkItems)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="WorkItems" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                                @item.Title
                                            </a>
                                        </td>
                                        <td><span class="badge @item.StatusBadgeClass">@item.Status</span></td>
                                        <td><span class="badge @item.PriorityBadgeClass">@item.Priority</span></td>
                                        <td>@item.AssigneeName</td>
                                        <td class="@(item.IsOverdue ? "text-danger fw-bold" : "")">
                                            @if (item.IsOverdue)
                                            {
                                                <i class="fas fa-exclamation-triangle"></i>
                                            }
                                            @(item.DueDate?.ToString("yyyy-MM-dd") ?? "-")
                                        </td>
                                        <td>
                                            <a asp-controller="WorkItems" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <!-- Info Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-info-circle"></i> Project Info</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small">Owner</label>
                    <div><i class="fas fa-user"></i> @Model.OwnerName</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Start Date</label>
                    <div><i class="fas fa-calendar-alt"></i> @Model.StartDate.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">End Date</label>
                    <div><i class="fas fa-calendar-check"></i> @(Model.EndDate?.ToString("yyyy-MM-dd") ?? "Not set")</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Created At</label>
                    <div><i class="fas fa-clock"></i> @Model.CreatedAt.ToString("yyyy-MM-dd")</div>
                </div>
            </div>
        </div>
        
        <!-- Team Members Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-users"></i> Team Members (@Model.TeamMembers.Count)</h5>
            </div>
            <div class="card-body">
                @if (!Model.TeamMembers.Any())
                {
                    <p class="text-muted text-center mb-0">No team members yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var member in Model.TeamMembers)
                        {
                            <li class="mb-2 pb-2 border-bottom">
                                <i class="fas fa-user-circle"></i> <strong>@member.UserName</strong>
                                <br />
                                <small class="text-muted ms-3">Role: @member.Role</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
        
        <!-- Stats Card -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Quick Stats</h5>
            </div>
            <div class="card-body text-center">
                <h2 class="mb-0">@Model.WorkItems.Count(w => w.Status == "Done") / @Model.WorkItems.Count</h2>
                <p class="text-muted">Tasks Completed</p>
                <div class="progress mb-2">
                    <div class="progress-bar bg-success" style="width: @(Model.WorkItems.Count > 0 ? (double)Model.WorkItems.Count(w => w.Status == "Done") / Model.WorkItems.Count * 100 : 0)%"></div>
                </div>
                <small class="text-muted">@(Model.WorkItems.Count > 0 ? Math.Round((double)Model.WorkItems.Count(w => w.Status == "Done") / Model.WorkItems.Count * 100, 1) : 0)% Complete</small>
            </div>
        </div>
    </div>
</div>