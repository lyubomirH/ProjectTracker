@{
    ViewData["Title"] = "Unauthorized Access";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-4 text-center">
                    <i class="fas fa-lock fa-3x mb-2"></i>
                    <h1 class="display-4 mb-0">401</h1>
                    <h3 class="mb-0">Unauthorized Access</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <h4 class="text-danger mb-3">Access Denied!</h4>
                    <p class="lead text-muted mb-4">
                        You don't have permission to view this page.
                    </p>
                    <div class="d-flex gap-3 justify-content-center">
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Log In
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-home"></i> Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>