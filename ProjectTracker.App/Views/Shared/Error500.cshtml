@{
    ViewData["Title"] = "Server Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-4 text-center">
                    <i class="fas fa-server fa-3x mb-2"></i>
                    <h1 class="display-4 mb-0">500</h1>
                    <h3 class="mb-0">Internal Server Error</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <h4 class="text-danger mb-3">Something went wrong!</h4>
                    <p class="lead text-muted mb-4">
                        We're experiencing technical difficulties. Please try again later.
                    </p>
                    <div class="d-flex gap-3 justify-content-center">
                        <button onclick="window.location.reload();" class="btn btn-primary">
                            <i class="fas fa-sync-alt"></i> Try Again
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-home"></i> Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>